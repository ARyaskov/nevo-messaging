{
  "name": "@riaskov/nevo-messaging-nats-example",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "npx rimraf ./dist/ && yarn type:check && nest start --builder swc",
    "type:check": "npx tsc --noEmit",
    "build": "yarn type:check && nest build --builder swc"
  },
  "dependencies": {
    "@nestjs/common": "11.1.4",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.4",
    "@nestjs/platform-fastify": "11.1.4",
    "@riaskov/nevo-messaging": "../../",
    "dotenv": "17.2.0",
    "nats": "2.29.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.10",
    "@swc/cli": "0.7.8",
    "@swc/core": "1.13.4",
    "@types/node": "24.0.14",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "typescript": "5.9.2"
  }
}
