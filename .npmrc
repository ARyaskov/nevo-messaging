# pnpm: don't fail when a transitive dep's `engines.node` doesn't match.
# semver treats prerelease versions (Node nightlies) as not satisfying plain ranges
# even when the numeric major is greater — engine-strict=false relaxes the check.
engine-strict=false

# Keep peer-dep resolution permissive so peer-optional packages don't block install.
auto-install-peers=false
strict-peer-dependencies=false
