{
  "name": "@riaskov/nevo-messaging",
  "version": "2.3.2",
  "description": "Microservices messaging framework for NestJS with NATS/Kafka/SocketIO/HTTP transport, MessagePack, retry/circuit-breaker, OTel, schema validation, DLQ, idempotency, saga, outbox, metrics, health, DevTools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*.js"
  },
  "bin": {
    "nevo-contract": "dist/cli/contract.js",
    "nevo-gen": "dist/cli/gen-service.js"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc && node -e \"try { require('fs').chmodSync('dist/cli/contract.js', 0o755); require('fs').chmodSync('dist/cli/gen-service.js', 0o755) } catch {}\"",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run clean && pnpm run lint && pnpm run test && pnpm run build",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"test/**/*.test.ts\"",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "nestjs",
    "microservices",
    "kafka",
    "nats",
    "messaging",
    "msgpack",
    "messagepack",
    "opentelemetry",
    "saga",
    "outbox",
    "circuit-breaker",
    "retry",
    "dlq",
    "nevo"
  ],
  "author": "Andrei Riaskov <code@riaskov.com>",
  "license": "MIT",
  "peerDependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@nats-io/jetstream": "^3.0.0",
    "@nats-io/nats-core": "^3.0.0",
    "@nats-io/transport-node": "^3.0.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/microservices": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "@opentelemetry/api": "^1.9.0",
    "cacheable-lookup": "^7.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "fast-json-stringify": "^6.0.0",
    "kafkajs": "^2.2.4",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "undici": "^7.0.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
